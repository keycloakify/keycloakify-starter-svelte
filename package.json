{
  "name": "keycloakify-starter-svelte",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build-keycloak-theme": "npm run build && keycloakify build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write '**/*.{ts,html,json,md,svelte}'",
    "lint": "yarn format && eslint . --fix",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@keycloakify/svelte": "^0.2.9",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-svelte-csf": "5.0.11",
    "@storybook/svelte": "^10.2.19",
    "@storybook/svelte-vite": "^10.2.19",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.8",
    "@types/eslint": "^9.6.1",
    "dompurify": "^3.3.3",
    "eslint": "10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-storybook": "^10.2.19",
    "eslint-plugin-svelte": "^3.15.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "keycloakify": "^11.15.1",
    "npm-check-updates": "^19.6.3",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "storybook": "^10.2.19",
    "svelte": "^5.53.11",
    "svelte-check": "^4.4.5",
    "tsafe": "^1.8.12",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1"
  }
}
